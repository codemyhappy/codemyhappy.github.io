{
    "workbench.colorCustomizations": {
        "activityBar.background": "#05cece",
        "activityBar.activeBackground": "#05cece",
        "activityBar.activeBorder": "#05cece",
        "activityBar.foreground": "#15202b",
        "activityBar.inactiveForeground": "#15202b99",
        "activityBarBadge.background": "#05cece",
        "activityBarBadge.foreground": "#15202b",
        "titleBar.activeBackground": "#05cece",
        "titleBar.inactiveBackground": "#05cece",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.inactiveForeground": "#e7e7e799",
        "statusBar.background": "#05cece",
        "statusBarItem.hoverBackground": "#05cece",
        "statusBar.foreground": "#e7e7e7"
    },
    "MarkdownPublisher.EnableChromePreview": false,

    // 控制markdown中粘贴图片的位置：`文章配图/同名文件夹/图片名称.后缀`
    "markdown.copyFiles.destination": {
        // "**/*": "${documentDirName}/文章配图/${documentBaseName}/${fileName}"
        "**/*": "${documentWorkspaceFolder}/public/blog-imgs/${documentBaseName}/${fileName}"
    }
}